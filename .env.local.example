# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# n8n Integration
N8N_BASE_URL=https://your-n8n-instance.app.n8n.cloud
N8N_API_KEY=your-n8n-api-key
N8N_WEBHOOK_SECRET=my-webhook-secret-123

# AI Configuration
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=openai/gpt-oss-120b
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# WhatsApp Business API
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ─── Unused / Future ────────────────────────────────────────────────
# These are not currently referenced in the codebase.
# Uncomment and configure when the corresponding integrations are added.

# ANTHROPIC_API_KEY=your-anthropic-api-key
