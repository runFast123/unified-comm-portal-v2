# ─── Supabase (unified-comm-portal-test ONLY) ─────────────────────────
# Hard-bound to project ref: mpgmwyobrzhqamtcrtjg
NEXT_PUBLIC_SUPABASE_URL=https://mpgmwyobrzhqamtcrtjg.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_a33ueV9fnktT1geaBAKvFQ_PddaaP81
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key-from-supabase-dashboard>
SUPABASE_EXPECTED_PROJECT_REF=mpgmwyobrzhqamtcrtjg

# ─── AI (NVIDIA NIM) ──────────────────────────────────────────────────
AI_BASE_URL=https://integrate.api.nvidia.com/v1
AI_API_KEY=your-ai-api-key
AI_MODEL=meta/llama-3.3-70b-instruct
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7

# ─── Webhook shared secret (internal cron + channel webhooks) ─────────
WEBHOOK_SECRET=change-me-to-a-long-random-string

# ─── Channel config encryption ────────────────────────────────────────
# 32-byte base64 key used to encrypt per-account SMTP/Graph/WhatsApp credentials
# stored in the channel_configs + integration_settings tables. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Legacy single-key mode: set this and leave CHANNEL_CONFIG_ENCRYPTION_KEYS
# blank. The app treats it as keyId 'k0' internally.
CHANNEL_CONFIG_ENCRYPTION_KEY=

# Optional: for key rotation, specify multiple keys. Format: "id:base64_32byte_key,..."
# The FIRST entry is used for new encryptions; ALL entries are tried on decrypt.
# To rotate:  (1) prepend a fresh key, deploy, let saves re-encrypt lazily;
#             (2) once migrated, drop the old entry from this list.
# CHANNEL_CONFIG_ENCRYPTION_KEYS=k2:newNewKeyBase64==,k1:oldKeyBase64==

# ─── Email SEND (SMTP — replaces n8n Gmail flow) ──────────────────────
# Works with Gmail (app password), Office365, SendGrid, Mailgun, etc.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-mailbox@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Unified Comm Portal

# ─── Email RECEIVE (IMAP — replaces n8n Gmail monitor) ────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-mailbox@example.com
IMAP_PASSWORD=your-app-password

# ─── Gmail OAuth (optional — enables "Sign in with Google" for email accounts) ──
# When set, admins can connect Gmail accounts by OAuth consent instead of
# storing an IMAP/SMTP app password. Protocol stays SMTP+IMAP; only the
# auth mechanism changes (XOAUTH2).
#
# Create an OAuth client at https://console.cloud.google.com/apis/credentials
#   Type: Web application
#   Authorized redirect URI: {YOUR_APP_URL}/api/auth/gmail/callback
#     e.g. http://localhost:3000/api/auth/gmail/callback
#          https://your-domain.com/api/auth/gmail/callback
#   Required scopes: https://mail.google.com/ , openid , email , profile
# One Google Cloud app covers every end-user — each admin just clicks
# "Sign in with Google" on their account row to grant their own mailbox.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─── Microsoft Teams (Graph API — replaces n8n Teams flow) ────────────
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# ─── WhatsApp (Meta Cloud API — replaces n8n WhatsApp flow) ───────────
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-access-token
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_GRAPH_VERSION=v21.0

# ─── Logging ──────────────────────────────────────────────────────────
# Default (unset / any other value) emits human-friendly single-line logs:
#   [12:34:56] [info] [webhook/email_received] Email from … {request_id=…}
# Set LOG_FORMAT=json in production to emit one JSON object per line —
# Vercel/Datadog/Loki ingest these directly. Top-level fields include
# `ts`, `level`, `category`, `event`, `request_id`, `account_id`,
# `user_id`, `duration_ms`, plus a nested `details` blob.
# LOG_FORMAT=json

# ─── Sentry (optional — error tracking) ──────────────────────────────
# Get DSN from https://sentry.io/settings/{org}/projects/{project}/keys/
# Server DSN (won't expose to browser):
SENTRY_DSN=
# Client DSN (must be NEXT_PUBLIC_ prefix to expose to browser):
NEXT_PUBLIC_SENTRY_DSN=
# Sample rate for performance traces (0..1). 0 = errors only.
SENTRY_TRACES_SAMPLE_RATE=0
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Set SENTRY_DEV=1 to enable Sentry locally (otherwise only fires in production)
# SENTRY_DEV=

# Source map uploads (only needed for production builds with stack traces):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
